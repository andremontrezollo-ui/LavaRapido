# Frontend environment variables
# Copy this file to .env and fill in the values from your Supabase project settings.
# Never commit .env to source control.

# Supabase project URL (found in Project Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe to expose — no service-role privileges)
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Supabase project ID (used for reference only)
VITE_SUPABASE_PROJECT_ID=your-project-id
