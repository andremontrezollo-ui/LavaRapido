# Frontend environment variables
# Copy this file to .env and fill with your real values.
# NEVER commit .env to version control.

# Supabase project reference (found in Project Settings → General)
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Supabase anonymous / publishable key (safe for frontend use)
# Found in Project Settings → API → Project API keys → anon public
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Supabase project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
