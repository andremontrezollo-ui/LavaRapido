# Environment Configuration — Frontend
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.

# Supabase project URL (Settings > API)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase anonymous/public key (Settings > API > Project API keys > anon public)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase project reference (used internally by some tooling)
VITE_SUPABASE_PROJECT_ID=<project-ref>
