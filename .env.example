# ============================================================
# Environment Variables — DEMO / SIMULATOR / PROTOTYPE
# ============================================================
# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file.
#
# All keys below are required for the frontend to function.
# The app will display a clear error message if any are missing.
# ============================================================

# Supabase project URL (from Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key (safe to expose in browser; RLS enforces access)
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Optional: Supabase project reference ID (used for Supabase CLI)
# VITE_SUPABASE_PROJECT_ID=your-project-ref
