# Environment variables for ShadowMix
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to version control — it contains real credentials.

# Supabase project URL (found in: Supabase Dashboard → Settings → API → Project URL)
VITE_SUPABASE_URL=

# Supabase anonymous/public key (found in: Supabase Dashboard → Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=
