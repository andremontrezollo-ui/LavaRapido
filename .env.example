# Frontend environment variables — copy to .env and fill in your values
# NEVER commit the real .env file to version control

# Supabase project URL (e.g. https://<project-id>.supabase.co)
VITE_SUPABASE_URL=

# Supabase anonymous / publishable key (safe for the browser, but still treat as a secret)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase project ID (used by some Supabase CLI commands)
VITE_SUPABASE_PROJECT_ID=
