# Environment Configuration
# Copy to .env and fill with real values — NEVER commit .env

# Application
APP_ENV=development
LOG_LEVEL=info

# PostgreSQL (required)
DATABASE_URL=postgresql://lavarapido:CHANGE_ME@localhost:5432/lavarapido
# Individual fields are used if DATABASE_URL is not set
DB_HOST=localhost
DB_PORT=5432
DB_USER=lavarapido
DB_PASSWORD=CHANGE_ME
DB_NAME=lavarapido
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000

# Redis (required)
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# Docker secrets — used in docker-compose.yml only
POSTGRES_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME

# JWT (required in production — provide at least one)
JWT_SECRET=
JWT_PUBLIC_KEY=

# Rate Limiting (required)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15

# Supabase (optional — legacy)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sessions
SESSION_TTL_MINUTES=30

# Blockchain
CONFIRMATION_THRESHOLD=6

# Outbox
OUTBOX_POLL_INTERVAL_MS=5000

# Retries
MAX_RETRIES=3

# Locks
LOCK_TTL_SECONDS=30
