# Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.

# ── Application ────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info

# ── PostgreSQL ─────────────────────────────────────────────────
# Used by docker-compose; change to your real values.
POSTGRES_USER=lavarapido
POSTGRES_PASSWORD=  # REQUIRED: set a strong random password (e.g. openssl rand -hex 32)
POSTGRES_DB=lavarapido

# Full connection URL consumed by the backend — replace <POSTGRES_PASSWORD> with the value above.
DATABASE_URL=postgres://lavarapido:<POSTGRES_PASSWORD>@localhost:5432/lavarapido

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=  # REQUIRED: set a strong random password (e.g. openssl rand -hex 32)
REDIS_URL=redis://:<REDIS_PASSWORD>@localhost:6379

# ── Auth ───────────────────────────────────────────────────────
# Provide either JWT_SECRET (symmetric) or JWT_PUBLIC_KEY (asymmetric).
JWT_SECRET=
# JWT_PUBLIC_KEY=

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# ── Supabase (legacy edge-functions — optional) ────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Sessions ───────────────────────────────────────────────────
SESSION_TTL_MINUTES=30

# ── Blockchain ────────────────────────────────────────────────
CONFIRMATION_THRESHOLD=6

# ── Outbox ────────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_MS=5000

# ── Retries / Locks ───────────────────────────────────────────
MAX_RETRIES=3
LOCK_TTL_SECONDS=30
