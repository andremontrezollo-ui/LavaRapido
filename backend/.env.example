# Environment Configuration
# Copy to .env and fill with real values — NEVER commit .env to version control

# Application
APP_ENV=development
LOG_LEVEL=info

# ──────────────────────────────────────────────────────
# Database (required in production)
# ──────────────────────────────────────────────────────
DATABASE_URL=postgres://lavarapido:<YOUR_POSTGRES_PASSWORD>@localhost:5432/lavarapido

# ──────────────────────────────────────────────────────
# Redis (required in production)
# ──────────────────────────────────────────────────────
REDIS_URL=redis://:<YOUR_REDIS_PASSWORD>@localhost:6379

# ──────────────────────────────────────────────────────
# Authentication (required)
# ──────────────────────────────────────────────────────
JWT_SECRET=<replace-with-a-long-random-secret-min-32-chars>

# ──────────────────────────────────────────────────────
# Docker Compose (used by docker-compose.yml only)
# ──────────────────────────────────────────────────────
POSTGRES_USER=lavarapido
POSTGRES_PASSWORD=<YOUR_POSTGRES_PASSWORD>
POSTGRES_DB=lavarapido
REDIS_PASSWORD=<YOUR_REDIS_PASSWORD>

# ──────────────────────────────────────────────────────
# Supabase (legacy / edge functions)
# ──────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MINUTES=10

# Sessions
SESSION_TTL_MINUTES=30

# Blockchain
CONFIRMATION_THRESHOLD=6

# Outbox
OUTBOX_POLL_INTERVAL_MS=5000

# Retries
MAX_RETRIES=3

# Locks
LOCK_TTL_SECONDS=30
