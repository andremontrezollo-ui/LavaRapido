# Environment Configuration
# Copy to .env and fill with real values

# Database
DATABASE_URL=postgresql://lava:lava_secret@localhost:5432/lavarapido
PG_HOST=localhost
PG_PORT=5432
PG_USER=lava
PG_PASSWORD=lava_secret
PG_DATABASE=lavarapido
PG_MAX_CONNECTIONS=20

# Redis
REDIS_URL=redis://:redis_secret@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# JWT
JWT_SECRET=your-super-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY=3600
JWT_ISSUER=lavarapido
JWT_AUDIENCE=lavarapido-api

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=600

# App
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Sessions
SESSION_TTL_MINUTES=30

# Blockchain
CONFIRMATION_THRESHOLD=6

# Outbox
OUTBOX_POLL_INTERVAL_MS=5000

# Retries
MAX_RETRIES=3

# Locks
LOCK_TTL_SECONDS=30

# HTTP Server
HTTP_PORT=3000
HTTP_HOST=0.0.0.0
APP_VERSION=1.0.0

# Supabase (legacy / external auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

