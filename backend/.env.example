# Environment Configuration
# Copy to .env and fill with real values

# Application
APP_ENV=development
LOG_LEVEL=info

# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/lavarapido

# Redis (required)
REDIS_URL=redis://localhost:6379

# Supabase (optional — needed for Supabase integrations)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# HTTP Server
HTTP_PORT=3000
HTTP_HOST=0.0.0.0

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MINUTES=10

# Sessions
SESSION_TTL_MINUTES=30

# Blockchain
CONFIRMATION_THRESHOLD=6

# Outbox
OUTBOX_POLL_INTERVAL_MS=5000

# Retries
MAX_RETRIES=3

# Locks
LOCK_TTL_SECONDS=30
